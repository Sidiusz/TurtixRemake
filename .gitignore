# ============================================================
# Turtix remake. Track the whole Unity project (Assets incl. art/audio,
# ProjectSettings, Packages, Tools). Ignore: original game at root/Content,
# Unity-generated dirs, build artifacts, debug captures, parser outputs.
# ============================================================

# ---- Original game (root + Content) — not part of the remake repo ----
/Content/
/Turtix.exe
/Uninstall.*
/unins000.*
/*.dll
/Game.dat
/Highscore.dat
/Profile.dat
/license.txt
/manifest.xml
/partner.ini
/registrator.ini
main*.cs
/main.cs.dso
/console.log
/local.log
*.tille
*.gui
*.eff
*.uft
Mod Workspace/Tools/main.cs.*

# ---- Parser outputs / logs (regenerated by the .py scripts) ----
/Mod Workspace/Tools/out/
/Mod Workspace/Logs/

# ---- Python caches ----
__pycache__/
*.pyc

# ---- Unity: generated / local (NOT the Assets) ----
/Mod Workspace/Unity Project/TurtixRemake/[Ll]ibrary/
/Mod Workspace/Unity Project/TurtixRemake/[Tt]emp/
/Mod Workspace/Unity Project/TurtixRemake/[Oo]bj/
/Mod Workspace/Unity Project/TurtixRemake/[Bb]uild/
/Mod Workspace/Unity Project/TurtixRemake/[Bb]uilds/
/Mod Workspace/Unity Project/TurtixRemake/[Ll]ogs/
/Mod Workspace/Unity Project/TurtixRemake/[Uu]serSettings/
/Mod Workspace/Unity Project/TurtixRemake/[Mm]emoryCaptures/
/Mod Workspace/Unity Project/TurtixRemake/.vs/
/Mod Workspace/Unity Project/TurtixRemake/.vsconfig

# auto-generated solution/project files
*.csproj
*.sln
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.opendb
*.VC.db

# ---- Assets we DON'T want in the repo ----
**/Assets/Screenshots/
**/Assets/Screenshots.meta
**/Assets/TutorialInfo/
**/Assets/TutorialInfo.meta

# ---- OS ----
.DS_Store
Thumbs.db
desktop.ini
